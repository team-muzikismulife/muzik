rules_version = '2';

// ══════════════════════════════════════════════════════════
// ⚠️ 데모 전용 (demo/spark-web 브랜치 · Spark 무료 플랜)
//
// 정본은 이게 아니다. 팀 정본은 feature/17의 v2 읽기 전용 룰
// ("쓰기는 전부 Cloud Functions 경유", docs/백엔드설계.md §4)이다.
//
// Spark에선 Functions를 배포할 수 없어, 데모를 위해 **클라이언트 직접 쓰기**를
// 허용하되 핵심 불변식(소유권·정원·하루 1곡·필드 제한)을 Rules로 강제한다.
// Blaze를 켜면 정본(Functions) 아키텍처로 돌아간다.
// ══════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myUid() { return request.auth.uid; }
    function isMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(myUid()));
    }

    match /config/app { allow read: if true; }

    // ── 초대 코드 → roomId 역참조 ──
    // 개설 시 클라가 생성한다. 유일성은 클라 트랜잭션(create-if-absent)이 보장.
    // update/delete는 막아 코드 탈취를 방지.
    // **get만 허용한다.** allow read(=get+list)로 열면 로그인한 누구나 invites를 통째로
    // 긁어 모든 방의 초대 코드를 열거할 수 있다(Firestore list는 all-or-nothing). 코드는
    // 방의 유일한 열쇠라 치명적 — 데모의 클라 직접 쓰기도 get/create만 필요하다.
    match /invites/{code} {
      allow get:    if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['roomId'])
        && request.resource.data.roomId is string;
    }

    match /rooms/{roomId} {
      allow read: if isMember(roomId);

      // 개설: 본인이 방장, 멤버수 1로 시작, 이름 길이 제한
      allow create: if isSignedIn()
        && request.resource.data.createdBy == myUid()
        && request.resource.data.memberCount == 1
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20;

      // 입장: 비멤버가 memberCount를 **정확히 +1**, 상한 30. 다른 필드는 못 건드림.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
        && request.resource.data.memberCount == resource.data.memberCount + 1
        && request.resource.data.memberCount <= 30;

      // ── 멤버 ──
      match /members/{uid} {
        allow read: if isMember(roomId);
        // 본인 문서만. 개설·입장의 진입점이라 isMember를 요구하지 않는다.
        allow create, update: if isSignedIn()
          && uid == myUid()
          && request.resource.data.uid == myUid();
      }

      // ── 트랙 (하루 1곡) ──
      match /tracks/{trackId} {
        allow read: if isMember(roomId);
        // 문서 ID = {uid}_{dateKey} + create-only → 하루 1곡을 ID로 강제
        allow create: if isMember(roomId)
          && request.resource.data.uid == myUid()
          && trackId == myUid() + '_' + request.resource.data.dateKey;
        // 수정·삭제는 본인 곡만
        allow update, delete: if isMember(roomId) && resource.data.uid == myUid();
      }

      // ── 일자 집계 ── 멤버가 갱신 (곡 등록 시 trackCount 등)
      match /days/{dateKey} {
        allow read:  if isMember(roomId);
        allow write: if isMember(roomId);
      }
    }

    // ── 참여 중인 팀 목록 (온보딩) ──
    // collectionGroup('members').where('uid','==',myUid) — 내 멤버 문서만 읽힌다.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.uid == myUid();
    }
  }
}

rules_version = '2';

// ──────────────────────────────────────────────────
// MUZIK IS MY LIFE — Firestore Security Rules (v2)
// 정본: docs/백엔드설계.md §4
//
// 대원칙: **쓰기는 전부 Cloud Functions(Admin SDK) 경유. 클라이언트는 읽기 전용.**
// Admin SDK는 룰을 우회하므로, 여기서는 write를 한 줄도 열지 않는다.
// 하루 1곡·서버 시각 dateKey·초대 코드 유일성 같은 규칙을 클라이언트가 우회할 수 없게
// 만드는 가장 단순한 방법이다. 룰은 "누가 무엇을 읽을 수 있는가"에만 집중한다.
// ──────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 문서 read당 exists() 1회 → 비용이 있다. 리스트 쿼리는 컬렉션 단위 1회 평가.
    function isMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    // 킬스위치 등 원격 설정 (handoffMode) — 로그인 전에도 읽어야 한다
    match /config/app {
      allow read: if true;
    }

    // 방과 그 하위 문서는 **그 방의 멤버만** 읽는다
    match /rooms/{roomId} {
      allow read: if isMember(roomId);

      match /members/{uid}    { allow read: if isMember(roomId); }
      match /tracks/{trackId} { allow read: if isMember(roomId); }
      match /days/{dateKey}   { allow read: if isMember(roomId); }
    }

    // 초대 코드 → 방 역참조. 코드를 아는 사람은 roomId를 알 수 있어야 입장이 가능하다.
    // **get만 허용한다.** allow read(=get+list)로 열면 조건이 resource.data를 안 보므로
    // 로그인한 누구나 invites 컬렉션을 통째로 긁어 모든 방의 초대 코드를 열거할 수 있다
    // (Firestore list는 all-or-nothing). 코드는 방의 유일한 열쇠라 이건 치명적이다.
    match /invites/{code} {
      allow get: if isSignedIn();
    }

    // ── 참여 중인 팀 목록 (온보딩) ──
    // 내 멤버 문서는 roomId를 모르는 상태에서도 읽을 수 있어야 한다.
    // collectionGroup('members').where('uid','==',myUid) 조회가 여기에 걸린다.
    //
    // 주의: 룰이 resource.data.uid를 보므로 **클라이언트 쿼리도 같은 제약(where uid == myUid)을
    // 걸어야** 통과한다. 어긋나면 permission-denied가 나는데 원인이 룰인지 쿼리인지 헷갈린다.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}

# 개발은 Emulator Suite 기본 — .env 없이도 돈다 (projectId 미설정 시 demo-muzik 사용).
# 실 Firebase 프로젝트를 보려면 아래를 채우고 EXPO_PUBLIC_USE_EMULATOR=false 로 둔다.
EXPO_PUBLIC_USE_EMULATOR=true

# Firebase 콘솔 > 프로젝트 설정 > 웹 앱에서 복사 후 .env 로 저장
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# 배포된 웹 도메인 — 초대 링크(https://<도메인>/r/{코드}) 생성용 (src/lib/invite.ts).
# 웹에서는 현재 origin을 자동으로 쓰므로 비워둬도 된다. 네이티브(앱)에서 초대 링크를
# 보내려면 채운다. 비어 있으면 초대는 6자리 코드만으로 공유된다(코드 입력 화면으로 입장).
EXPO_PUBLIC_WEB_URL=
